# 本地开发环境配置示例
# 复制此文件为 application-local.yml 并修改配置

server:
  port: 8080

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/property_management?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false
    username: your_username
    password: your_password

  data:
    redis:
      host: localhost
      port: 6379
      password: # 如果Redis需要密码，在此填写

jwt:
  secret: your-jwt-secret-key
